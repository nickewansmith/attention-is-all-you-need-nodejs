{
  "name": "attention-is-all-you-need-nodejs",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "NestJS implementation of the Attention Is All You Need transformer",
  "author": "Nicholas Smith <nickewansmith@gmail.com>",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint '{src,apps,libs,test}/**/*.ts' --max-warnings=0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"libs/**/*.{ts,tsx}\"",
    "cli:train": "ts-node src/cli/train.ts",
    "cli:infer": "ts-node src/cli/infer.ts",
    "benchmark": "ts-node scripts/benchmark.ts",
    "benchmark:stream": "ts-node scripts/stream-benchmark.ts"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.0.6",
    "@huggingface/transformers": "^3.8.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/serve-static": "^4.0.2",
    "@tensorflow/tfjs-node": "^4.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.5",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.4",
    "@types/node": "^20.11.28",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
