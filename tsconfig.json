{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "target": "es2021",
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "paths": {
      "@app/*": ["src/*"],
      "@core/*": ["src/transformer-core/*"],
      "@training/*": ["src/training/*"],
      "@api/*": ["src/api/*"],
      "@tensor/*": ["src/tensor/*"]
    }
  },
  "exclude": ["node_modules", "dist"],
  "include": ["src/**/*", "test/**/*"]
}
